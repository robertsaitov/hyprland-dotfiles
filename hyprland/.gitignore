# Dynamic files generated by theme switching
# These files are symlinks or config files that change when you switch themes

# Icons (user-downloaded icons)
.icons/

# Theme symlinks and dynamic configs
.config/hypr/themes/theme.conf
.config/waybar/themes/theme.css
.config/rofi/themes/theme.rasi
.config/swww/wall.blur
.config/swww/wall.rofi
.config/swww/wall.set

# Dynamic theme configs (colors change when theme changes)
.config/hypr/themes/Wall-Dcol.conf
.config/hypr/themes/colors.conf
.config/hypr/themes/theme.conf
.config/hypr/userprefs.t2
.config/hypr/theme.ctl

# Dynamic color configs for applications
.config/gtk-3.0/settings.ini
.config/qt5ct/qt5ct.conf
.config/qt6ct/qt6ct.conf
.config/xsettingsd/xsettingsd.conf

# Dynamic Kvantum theme config
.config/Kvantum/kvantum.kvconfig
.config/Kvantum/Wall-Dcol/

# Dynamic dunst config
.config/dunst/Wall-Dcol.conf
.config/dunst/dunst.conf
.config/dunst/icons/hyprdots.svg
.config/dunst/icons/vol/

# Dynamic waybar config
.config/waybar/config.jsonc
.config/waybar/themes/Wall-Dcol.css

# Dynamic rofi config
.config/rofi/config.rasi
.config/rofi/themes/Wall-Dcol.rasi

# Dynamic scripts generated by theme system
.config/hypr/scripts/1
.config/hypr/scripts/2

# Monitor config (hardware specific)
.config/hypr/monitors.conf

# User preferences (local overrides)
.config/hypr/userprefs.conf

# Kvantum and Qt color directories (contain extracted themes)
.config/Kvantum/Catppuccin-*/
.config/qt5ct/colors/
.config/qt6ct/colors/

# Generated symlinks in config root
.config/Catppuccin-Mocha
